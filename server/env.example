PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fugigeek

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Resend (email) — get your API key at resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@fugigeek.com

# DPO by Network (payments) — get from dpogroup.com merchant portal
DPO_COMPANY_TOKEN=your_dpo_company_token
DPO_SERVICE_TYPE=your_dpo_service_type_id
DPO_API_URL=https://secure.3gdirectpay.com/API/v6/
DPO_PAYMENT_URL=https://secure.3gdirectpay.com/payv2.php

# Client URL (for CORS and redirect URLs)
CLIENT_URL=http://localhost:5173
